---
import BaseLayout from "@layouts/BaseLayout.astro";
import Section from "@components/Section.astro";
import Card from "@components/Card.astro";
import { personalInfo, experiences, projects, education, skills, languages } from "@shared/cv_data";
import avatar from "@assets/core/avatar.jpg";
import { Image } from "astro:assets";

const title = `CV - ${personalInfo.name}`;
---

<BaseLayout
  title={title}
  description={personalInfo.summary}
  showNavbar={true}
>
  <header class="pt-24 pb-12 bg-base-100 border-b border-base-content/10 min-h-[50vh] flex flex-col justify-center scroll-target">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-base-content w-full">
      <div class="flex flex-col md:flex-row items-center gap-12">
        <div class="relative w-56 h-56 rounded-3xl overflow-hidden shadow-2xl border-4 border-primary shrink-0 transition-transform hover:scale-105 animate-scale-in">
          <Image src={avatar} alt={personalInfo.name} class="w-full h-full object-cover" loading="eager" />
        </div>
        
        <div class="flex-1 text-center md:text-left">
          <h1 class="text-5xl md:text-7xl font-black mb-4 tracking-tighter text-base-content leading-none animate-fade-in-down">
            {personalInfo.name}
          </h1>
          <p class="text-2xl md:text-3xl font-bold text-primary mb-6 uppercase tracking-widest bg-primary/10 inline-block px-4 py-1 rounded-lg animate-fade-in" style="animation-delay: 0.05s">
            Ingeniero en Sistemas
          </p>
          <p class="text-xl md:text-2xl opacity-90 max-w-3xl leading-relaxed mb-8 text-base-content/90 font-medium font-sans animate-fade-in-up" style="animation-delay: 0.1s">
            {personalInfo.summary}
          </p>
          
          <div class="flex flex-wrap justify-center md:justify-start gap-6 animate-fade-in-up" style="animation-delay: 0.15s">
            <a href={`mailto:${personalInfo.email}`} class="btn btn-primary btn-lg shadow-lg hover:scale-105 transition-all font-black text-lg px-8 rounded-xl">
              CONTACTAR
            </a>
            <a href={personalInfo.github} target="_blank" class="btn btn-outline btn-lg border-2 hover:scale-105 transition-all font-black text-lg px-8 rounded-xl">
              GITHUB
            </a>
          </div>
        </div>
      </div>

      <div class="mt-16 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="p-6 bg-base-200/50 backdrop-blur rounded-2xl border border-base-content/5 flex flex-col gap-4 hover:bg-base-200 transition-all hover:-translate-y-1 group animate-fade-in-up" style="animation-delay: 0.2s">
          <div class="w-12 h-12 rounded-xl bg-primary flex items-center justify-center text-primary-content shadow-lg shadow-primary/20 shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <div>
            <p class="text-xs font-black uppercase tracking-widest opacity-40 mb-1">Ubicación</p>
            <p class="font-bold text-lg leading-tight">{personalInfo.location}</p>
          </div>
        </div>

        <div class="p-6 bg-base-200/50 backdrop-blur rounded-2xl border border-base-content/5 flex flex-col gap-4 hover:bg-base-200 transition-all hover:-translate-y-1 group animate-fade-in-up" style="animation-delay: 0.25s">
          <div class="w-12 h-12 rounded-xl bg-secondary flex items-center justify-center text-secondary-content shadow-lg shadow-secondary/20 shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <div class="break-all">
            <p class="text-xs font-black uppercase tracking-widest opacity-40 mb-1">Email</p>
            <a href={`mailto:${personalInfo.email}`} class="font-bold text-lg hover:text-primary transition-colors leading-tight decoration-primary/30 underline-offset-4 hover:underline">{personalInfo.email}</a>
          </div>
        </div>

        <div class="p-6 bg-base-200/50 backdrop-blur rounded-2xl border border-base-content/5 flex flex-col gap-4 hover:bg-base-200 transition-all hover:-translate-y-1 group animate-fade-in-up" style="animation-delay: 0.3s">
          <div class="w-12 h-12 rounded-xl bg-accent flex items-center justify-center text-accent-content shadow-lg shadow-accent/20 shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <div>
            <p class="text-xs font-black uppercase tracking-widest opacity-40 mb-1">Teléfono</p>
            <p class="font-bold text-lg leading-tight">{personalInfo.phone}</p>
          </div>
        </div>

        <div class="p-6 bg-base-200/50 backdrop-blur rounded-2xl border border-base-content/5 flex flex-col gap-4 hover:bg-base-200 transition-all hover:-translate-y-1 group animate-fade-in-up" style="animation-delay: 0.35s">
          <div class="w-12 h-12 rounded-xl bg-info flex items-center justify-center text-info-content shadow-lg shadow-info/20 shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          </div>
          <div>
            <p class="text-xs font-black uppercase tracking-widest opacity-40 mb-1">GitHub</p>
            <a href={personalInfo.github} target="_blank" class="font-bold text-lg hover:text-primary transition-colors leading-tight decoration-primary/30 underline-offset-4 hover:underline">MetaDandy</a>
          </div>
        </div>
      </div>
    </div>
  </header>

  <section id="experience" class="py-20 bg-base-200 scroll-target">
    <div class="max-w-6xl mx-auto px-4 text-base-content">
      <div class="text-center mb-16 font-black uppercase tracking-tight">
        <h2 class="text-4xl md:text-5xl mb-4">Experiencia Profesional</h2>
        <div class="w-24 h-1.5 bg-primary mx-auto rounded-full"></div>
      </div>
      <div class="space-y-12">
        {experiences.map((exp, index) => (
          <div 
            class="bg-base-100 p-8 rounded-3xl shadow-xl border border-base-content/5 hover:border-primary/30 transition-all group animate-fade-in-up"
            style={`animation-delay: ${index * 0.05}s`}
          >
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6 gap-4">
              <div>
                <h3 class="text-2xl md:text-3xl font-black text-base-content group-hover:text-primary transition-colors">{exp.role}</h3>
                <p class="text-lg font-bold text-primary/80">{exp.company}</p>
              </div>
              <span class="px-4 py-2 bg-base-300 rounded-xl font-black text-sm uppercase tracking-wider">{exp.period}</span>
            </div>
            
            <p class="text-lg opacity-80 mb-6 leading-relaxed">
              {exp.description}
            </p>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
              {exp.responsibilities.map((res) => (
                <div class="flex gap-3 items-start">
                  <div class="mt-1.5 w-2 h-2 rounded-full bg-primary shrink-0"></div>
                  <p class="text-md opacity-90">{res}</p>
                </div>
              ))}
            </div>

            <div class="flex flex-wrap gap-2 pt-6 border-t border-base-content/5">
              {exp.technologies.map((tech) => (
                <span class="badge badge-outline badge-primary font-bold px-4 py-3">{tech}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="projects" class="py-20 bg-base-100">
    <div class="max-w-6xl mx-auto px-4 text-base-content">
      <div class="text-center mb-16 font-black uppercase tracking-tight">
        <h2 class="text-4xl md:text-5xl mb-4">Proyectos Destacados</h2>
        <div class="w-24 h-1.5 bg-secondary mx-auto rounded-full"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
        {projects.map((proj) => (
          <Card
            title={proj.title}
            description={proj.description}
            items={proj.highlights}
            variant="bordered"
          >
            <div class="mt-6 flex flex-wrap gap-2">
              {proj.technologies.map((tech) => (
                <span class="badge badge-secondary badge-outline badge-sm font-bold">
                  {tech}
                </span>
              ))}
            </div>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <Section id="skills" title="Habilidades Técnicas">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12 mt-12 text-left text-base-content">
      <div class="animate-fade-in-up" style="animation-delay: 0.05s">
        <h3 class="text-2xl font-black mb-6 border-l-4 border-primary pl-4 uppercase tracking-tighter">Lenguajes</h3>
        <ul class="space-y-3">
          {skills.languages.map(s => (
            <li class="flex items-center gap-2 font-medium opacity-80">
              <span class="w-1.5 h-1.5 bg-primary rounded-full"></span>
              {s}
            </li>
          ))}
        </ul>
      </div>
      
      <div class="animate-fade-in-up" style="animation-delay: 0.1s">
        <h3 class="text-2xl font-black mb-6 border-l-4 border-secondary pl-4 uppercase tracking-tighter">Frameworks</h3>
        <ul class="space-y-3">
          {skills.frameworks.map(s => (
            <li class="flex items-center gap-2 font-medium opacity-80">
              <span class="w-1.5 h-1.5 bg-secondary rounded-full"></span>
              {s}
            </li>
          ))}
        </ul>
      </div>

      <div class="animate-fade-in-up" style="animation-delay: 0.15s">
        <h3 class="text-2xl font-black mb-6 border-l-4 border-accent pl-4 uppercase tracking-tighter">Bases de Datos</h3>
        <ul class="space-y-3">
          {skills.databases.map(s => (
            <li class="flex items-center gap-2 font-medium opacity-80">
              <span class="w-1.5 h-1.5 bg-accent rounded-full"></span>
              {s}
            </li>
          ))}
        </ul>
      </div>

      <div class="animate-fade-in-up" style="animation-delay: 0.2s">
        <h3 class="text-2xl font-black mb-6 border-l-4 border-info pl-4 uppercase tracking-tighter">Herramientas</h3>
        <ul class="space-y-3">
          {(skills.tools || []).map((s: string) => (
            <li class="flex items-center gap-2 font-medium opacity-80">
              <span class="w-1.5 h-1.5 bg-info rounded-full"></span>
              {s}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </Section>

  <Section id="education" title="Formación e Idiomas">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 mt-8 text-left text-base-content">
      <div class="p-8 bg-base-200 rounded-3xl border border-base-content/5 animate-fade-in-up" style="animation-delay: 0.1s">
        <h3 class="text-2xl font-black mb-8 flex items-center gap-3 uppercase tracking-tighter">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path d="M12 14l9-5-9-5-9 5 9 5z" />
            <path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
          </svg>
          Educación
        </h3>
        {education.map(ed => (
          <div class="relative pl-8 before:absolute before:left-0 before:top-2 before:bottom-0 before:w-0.5 before:bg-primary/30 mb-6 last:mb-0">
            <div class="absolute -left-1 top-2 w-2.5 h-2.5 bg-primary rounded-full"></div>
            <p class="text-xl font-black leading-tight mb-1">{ed.degree}</p>
            <p class="text-primary font-bold mb-2">{ed.institution}</p>
            <p class="text-sm opacity-60 italic">{ed.period}</p>
          </div>
        ))}
      </div>

      <div class="p-8 bg-base-200 rounded-3xl border border-base-content/5 animate-fade-in-up" style="animation-delay: 0.2s">
        <h3 class="text-2xl font-black mb-8 flex items-center gap-3 uppercase tracking-tighter">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5a18.062 18.062 0 01-4.827 0M7 20l4-4.312M14.5 9h5.132a2 2 0 011.954 1.588l.94 4.704a2 2 0 01-1.954 2.412H14.5M10.5 21v-4m0 0H7m3.5 0h3.5" />
          </svg>
          Idiomas
        </h3>
        <ul class="space-y-6">
          {languages.map(lang => (
            <li class="flex flex-col gap-1">
              <span class="text-xl font-black">{lang.language}</span>
              <div class="flex items-center gap-4">
                <progress class="progress progress-secondary flex-1" value={lang.level.includes('Nativo') ? 100 : 70} max="100"></progress>
                <span class="text-sm font-bold opacity-70 whitespace-nowrap">{lang.level}</span>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </Section>

  <footer class="py-24 bg-primary text-primary-content text-center">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-4xl md:text-6xl font-black mb-6 tracking-tighter uppercase">¿Interesado en trabajar conmigo?</h2>
      <p class="text-xl md:text-2xl mb-12 opacity-90 font-medium">Estoy abierto a nuevas oportunidades y desafíos tecnológicos.</p>
      <div class="flex flex-col sm:flex-row justify-center gap-6">
        <a href={`mailto:${personalInfo.email}`} class="btn btn-lg bg-base-100 text-primary border-none hover:bg-base-200">
          Contactar ahora
        </a>
        <a href={personalInfo.github} target="_blank" rel="noopener noreferrer" class="btn btn-lg btn-outline border-primary-content text-primary-content hover:bg-primary-content hover:text-primary">
          Explorar GitHub
        </a>
      </div>
    </div>
  </footer>
</BaseLayout>
