---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  id: string;
  imageSrc: string | ImageMetadata | Promise<{ default: ImageMetadata }>;
  imageAlt?: string;
  title?: string;
  items?: string[];
}

const { id, imageSrc, imageAlt = 'Modal image', title, items } = Astro.props;
---


<dialog id={id} class="modal">
  <div class="modal-box max-w-7xl w-11/12 md:w-5/6 bg-base-100 p-0 overflow-hidden flex flex-col md:flex-row h-auto max-h-[90vh]">
    <button
      class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2 z-20 bg-base-100/50"
      onclick={`document.getElementById('${id}').close()`}
    >
      ✕
    </button>

    <!-- Lado izquierdo: Imagen -->
    <div class="w-full md:w-2/3 bg-black flex items-center justify-center overflow-hidden">
      <Image 
        src={imageSrc as any} 
        alt={imageAlt} 
        width={1200} 
        height={800} 
        loading="lazy" 
        class="w-full h-full object-contain" 
      />
    </div>


    <!-- Lado derecho: Título e Items -->
    <div class="w-full md:w-1/3 p-6 md:p-8 bg-base-100 flex flex-col overflow-y-auto">
      {title && (
        <h3 class="text-2xl font-bold mb-4 text-base-content border-b border-base-300 pb-2">
          {title}
        </h3>
      )}
      
      {items && items.length > 0 && (
        <ul class="space-y-3 grow">
          {items.map((item) => (
            <li class="flex items-start gap-3">
              <span class="text-primary mt-1 shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
              </span>
              <span class="text-base-content/80 text-sm md:text-base leading-snug">{item}</span>
            </li>
          ))}
        </ul>
      )}

      {!items && !title && (
        <div class="grow flex items-center justify-center text-base-content/40 italic">
          Sin detalles adicionales
        </div>
      )}
      
      <div class="mt-auto pt-8">
        <button 
          class="btn btn-primary btn-block"
          onclick={`document.getElementById('${id}').close()`}>
          Cerrar
        </button>
      </div>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button type="submit">close</button>
  </form>
</dialog>

<style>
  dialog::backdrop {
    background-color: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(5px);
  }
  
  dialog {
    display: flex;
    align-items: center;
    justify-content: center;
  }
</style>
