---
import SocialButton from './Button.social.astro';
import type { Network } from '@type/network';

interface Props {
  network?: Network;
  href?: string;
}

const { 
  network = 'whatsapp', 
  href = 'https://wa.me/your-number' 
} = Astro.props;
---

<div class="fixed bottom-6 right-6 z-50">
  <SocialButton 
    network={network} 
    href={href} 
    size="lg" 
    showLabel={false}
  />
</div>
